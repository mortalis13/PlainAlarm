<resources>
  <style name="AppTheme" parent="Theme.AppCompat.Light">
    <item name="windowActionBar">false</item>
    <item name="windowNoTitle">true</item>
  </style>
  
  <style name="ClockEditTextStyle">
    <item name="android:inputType">number|textNoSuggestions</item>
    <item name="android:selectAllOnFocus">true</item>
    <item name="android:singleLine">true</item>
    
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:gravity">center</item>
    <item name="android:textSize">@dimen/clock_text_font_size</item>
    <item name="android:textColor">@color/clock_text_color</item>
    <item name="android:background">@null</item>
  </style>
  
  <style name="ClockSeparatorTextStyle">
    <item name="android:paddingBottom">@dimen/clock_separator_padding_bottom</item>
    <item name="android:gravity">center</item>
    <item name="android:text">:</item>
    <item name="android:textColor">@color/clock_text_color</item>
    <item name="android:textSize">@dimen/clock_separator_font_size</item>
    <item name="android:textStyle">bold</item>
  </style>
</resources>
